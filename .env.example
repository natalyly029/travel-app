# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App Configuration
NEXT_PUBLIC_APP_NAME=Travel App

# Database (optional, for server-side queries)
DATABASE_URL=postgresql://postgres:password@YOUR_PROJECT_REF.supabase.co:5432/postgres
